---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { categories, allServers } from '~/lib/data';

const counts = new Map<string, number>();
for (const s of allServers) counts.set(s.category, (counts.get(s.category) ?? 0) + 1);
---

<BaseLayout
  title="MCP Server Categories — MCP Directory"
  description="Browse Model Context Protocol servers by category: databases, devtools, productivity, AI, search, filesystem, communication, and more."
>
  <section class="px-4 mx-auto max-w-6xl pt-10 pb-20">
    <h1 class="text-3xl font-bold text-white">Categories</h1>
    <p class="text-slate-400 mt-2">Browse {allServers.length} servers across {categories.length} categories.</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
      {categories.map((c) => (
        <a href={`/categories/${c.id}/`} class="card p-5 group">
          <div class="flex items-center justify-between">
            <div class="font-semibold text-white group-hover:text-brand-100">{c.label}</div>
            <span class="text-xs text-slate-500">{counts.get(c.id) ?? 0}</span>
          </div>
          <p class="text-sm text-slate-400 mt-2 line-clamp-2">{c.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
