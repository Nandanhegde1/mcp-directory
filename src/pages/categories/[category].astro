---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServerCard from '~/components/ServerCard.astro';
import { categories, getServersByCategory, categoryLabel } from '~/lib/data';
import type { McpCategory } from '~/types';

export async function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.id } }));
}

const { category } = Astro.params;
const cat = category as McpCategory;
const meta = categories.find((c) => c.id === cat);
const servers = getServersByCategory(cat).sort((a, b) => b.stars - a.stars);
const label = categoryLabel(cat);
---

<BaseLayout
  title={`${label} MCP Servers (${servers.length}) — MCP Directory`}
  description={`${servers.length} ${label.toLowerCase()} Model Context Protocol servers. ${meta?.description ?? ''} Install instructions and configs included.`}
>
  <section class="px-4 mx-auto max-w-6xl pt-10 pb-20">
    <nav class="text-xs text-slate-500 mb-4">
      <a href="/" class="hover:text-white">Home</a> ·
      <a href="/categories/" class="hover:text-white">Categories</a> ·
      <span class="text-slate-400">{label}</span>
    </nav>

    <h1 class="text-3xl font-bold text-white">{label} MCP servers</h1>
    {meta && <p class="text-slate-300 mt-2 max-w-2xl">{meta.description}</p>}
    <p class="text-slate-500 text-sm mt-1">{servers.length} server{servers.length === 1 ? '' : 's'}</p>

    {servers.length === 0 ? (
      <p class="text-slate-400 mt-10">No servers in this category yet. <a class="text-brand-500 hover:text-brand-100 underline" href="/submit/">Submit one →</a></p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
        {servers.map((s) => <ServerCard server={s} />)}
      </div>
    )}
  </section>
</BaseLayout>
