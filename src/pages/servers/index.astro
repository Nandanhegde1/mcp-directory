---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServerCard from '~/components/ServerCard.astro';
import { allServers, categories } from '~/lib/data';

const sorted = [...allServers].sort((a, b) => b.stars - a.stars);
---

<BaseLayout
  title={`All MCP Servers (${sorted.length}) — MCP Directory`}
  description={`Browse all ${sorted.length} indexed Model Context Protocol servers. Filter by category, search by name, see install commands.`}
>
  <section class="px-4 mx-auto max-w-6xl pt-10">
    <h1 class="text-3xl font-bold text-white">All MCP servers</h1>
    <p class="text-slate-400 mt-2">{sorted.length} servers indexed.</p>

    <div class="mt-6 grid sm:grid-cols-[1fr_auto_auto] gap-3">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-500 pointer-events-none" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 3.4 9.83l3.13 3.14a.75.75 0 1 0 1.06-1.06l-3.13-3.14A5.5 5.5 0 0 0 9 3.5ZM5 9a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z" clip-rule="evenodd"/></svg>
        <input
          type="search"
          id="search"
          placeholder="Search name, description, owner, topic… (press / to focus)"
          autocomplete="off"
          class="w-full pl-10 pr-3 py-2.5 rounded-lg bg-slate-900 border border-slate-800 text-white placeholder:text-slate-500 focus:outline-none focus:border-brand-500"
        />
      </div>
      <select
        id="category-filter"
        class="px-3 py-2.5 rounded-lg bg-slate-900 border border-slate-800 text-white focus:outline-none focus:border-brand-500"
      >
        <option value="">All categories</option>
        {categories.map((c) => <option value={c.id}>{c.label}</option>)}
      </select>
      <select
        id="sort"
        class="px-3 py-2.5 rounded-lg bg-slate-900 border border-slate-800 text-white focus:outline-none focus:border-brand-500"
      >
        <option value="stars">Most stars</option>
        <option value="name">Name (A–Z)</option>
        <option value="recent">Recently updated</option>
      </select>
    </div>

    <div class="mt-3 flex items-center justify-between flex-wrap gap-2">
      <p id="result-count" class="text-sm text-slate-400">{sorted.length} results</p>
      <button id="clear" type="button" class="text-xs text-slate-500 hover:text-white hidden">Clear filters</button>
    </div>
  </section>

  <section class="px-4 mx-auto max-w-6xl mt-6 mb-20">
    {sorted.length === 0 ? (
      <p class="text-slate-400">No servers indexed yet. Run the scraper.</p>
    ) : (
      <>
        <div id="server-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {sorted.map((s) => <ServerCard server={s} />)}
        </div>
        <div id="empty-state" class="hidden text-center py-16">
          <p class="text-slate-300 text-lg">No servers match your search.</p>
          <p class="text-slate-500 text-sm mt-2">Try a different keyword or clear the category filter.</p>
        </div>
      </>
    )}
  </section>

  <script>
    const search = document.getElementById('search') as HTMLInputElement | null;
    const filter = document.getElementById('category-filter') as HTMLSelectElement | null;
    const sortSel = document.getElementById('sort') as HTMLSelectElement | null;
    const grid = document.getElementById('server-grid');
    const counter = document.getElementById('result-count');
    const empty = document.getElementById('empty-state');
    const clearBtn = document.getElementById('clear');

    if (grid && counter) {
      const cards = Array.from(grid.children) as HTMLElement[];
      const meta = cards.map((c, idx) => ({
        el: c,
        idx,
        name: c.dataset.serverName ?? '',
        desc: c.dataset.serverDesc ?? '',
        owner: c.dataset.serverOwner ?? '',
        topics: c.dataset.serverTopics ?? '',
        category: c.dataset.serverCategory ?? '',
      }));

      const tokenize = (q: string) => q.toLowerCase().split(/\s+/).map((t) => t.trim()).filter(Boolean);
      const score = (m: typeof meta[number], tokens: string[]) => {
        if (tokens.length === 0) return 1;
        let s = 0;
        for (const t of tokens) {
          if (m.name.includes(t)) s += 5;
          else if (m.owner.includes(t)) s += 3;
          else if (m.topics.includes(t)) s += 2;
          else if (m.desc.includes(t)) s += 1;
          else return 0;
        }
        return s;
      };

      const syncUrl = (q: string, cat: string, sort: string) => {
        const p = new URLSearchParams();
        if (q) p.set('q', q);
        if (cat) p.set('category', cat);
        if (sort && sort !== 'stars') p.set('sort', sort);
        const qs = p.toString();
        history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
      };

      const apply = () => {
        const q = (search?.value ?? '').trim().toLowerCase();
        const cat = filter?.value ?? '';
        const sort = sortSel?.value ?? 'stars';
        const tokens = tokenize(q);

        const filtered = meta
          .filter((m) => !cat || m.category === cat)
          .map((m) => ({ m, s: score(m, tokens) }))
          .filter((x) => x.s > 0);

        if (sort === 'name') filtered.sort((a, b) => a.m.name.localeCompare(b.m.name));
        else if (sort === 'recent') filtered.sort((a, b) => a.m.idx - b.m.idx);
        else if (tokens.length > 0) filtered.sort((a, b) => b.s - a.s || a.m.idx - b.m.idx);
        else filtered.sort((a, b) => a.m.idx - b.m.idx);

        for (const m of meta) m.el.style.display = 'none';
        const frag = document.createDocumentFragment();
        for (const x of filtered) { x.m.el.style.display = ''; frag.appendChild(x.m.el); }
        grid.appendChild(frag);

        const n = filtered.length;
        counter.textContent = `${n} result${n === 1 ? '' : 's'}${q ? ` for "${q}"` : ''}`;
        if (empty) empty.classList.toggle('hidden', n > 0);
        (grid as HTMLElement).style.display = n > 0 ? '' : 'none';

        const hasFilters = !!(q || cat || (sort && sort !== 'stars'));
        clearBtn?.classList.toggle('hidden', !hasFilters);
        syncUrl(q, cat, sort);
      };

      const params = new URLSearchParams(location.search);
      const iq = params.get('q'); if (iq && search) search.value = iq;
      const ic = params.get('category'); if (ic && filter) filter.value = ic;
      const is = params.get('sort'); if (is && sortSel) sortSel.value = is;

      let t: ReturnType<typeof setTimeout> | null = null;
      search?.addEventListener('input', () => { if (t) clearTimeout(t); t = setTimeout(apply, 80); });
      filter?.addEventListener('change', apply);
      sortSel?.addEventListener('change', apply);
      clearBtn?.addEventListener('click', () => {
        if (search) search.value = '';
        if (filter) filter.value = '';
        if (sortSel) sortSel.value = 'stars';
        apply();
        search?.focus();
      });
      document.addEventListener('keydown', (e) => {
        const tag = (document.activeElement as HTMLElement | null)?.tagName;
        if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA') {
          e.preventDefault();
          search?.focus();
        }
      });

      apply();
    }
  </script>
</BaseLayout>
