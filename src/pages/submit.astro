---
import BaseLayout from '~/layouts/BaseLayout.astro';
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || '';
const action = formspreeId ? `https://formspree.io/f/${formspreeId}` : '';
const issueUrl =
  'https://github.com/Nandanhegde1/mcp-directory/issues/new' +
  '?title=' + encodeURIComponent('Add server: <owner/repo>') +
  '&body=' + encodeURIComponent(
    '**GitHub repo URL:** https://github.com/owner/repo\n\n' +
    '**Suggested category:** (e.g. database, devtools, productivity)\n\n' +
    '**Notes:** \n');
---

<BaseLayout
  title="Submit your MCP server — MCP Directory"
  description="Add your Model Context Protocol server to the directory. Free listing, indexed within a week."
>
  <section class="px-4 mx-auto max-w-2xl pt-10 pb-20">
    <h1 class="text-3xl font-bold text-white">Submit an MCP server</h1>
    <p class="text-slate-300 mt-3">
      Free listings are reviewed weekly. Public GitHub repos whose name, description, or topics identify them
      as MCP projects are auto-indexed — you can also submit here to fast-track or fix metadata.
    </p>

    {action ? (
      <form action={action} method="POST" class="mt-8 space-y-4">
        <div>
          <label class="block text-sm text-slate-300 mb-1" for="repo">GitHub repo URL *</label>
          <input id="repo" name="repo" type="url" required placeholder="https://github.com/owner/repo" class="w-full px-3 py-2 rounded-lg bg-slate-900 border border-slate-800 text-white" />
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1" for="email">Your email *</label>
          <input id="email" name="email" type="email" required class="w-full px-3 py-2 rounded-lg bg-slate-900 border border-slate-800 text-white" />
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1" for="category">Suggested category</label>
          <input id="category" name="category" type="text" placeholder="e.g. database, devtools, productivity" class="w-full px-3 py-2 rounded-lg bg-slate-900 border border-slate-800 text-white" />
        </div>
        <div>
          <label class="block text-sm text-slate-300 mb-1" for="notes">Notes</label>
          <textarea id="notes" name="notes" rows="4" class="w-full px-3 py-2 rounded-lg bg-slate-900 border border-slate-800 text-white"></textarea>
        </div>
        <input type="text" name="_gotcha" style="display:none" />
        <button type="submit" class="px-5 py-2.5 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium">
          Submit
        </button>
      </form>
    ) : (
      <div class="mt-8 card p-6">
        <p class="text-slate-300">
          Submissions run through GitHub so they're public and trackable — open a pre-filled issue with your
          repo URL and suggested category:
        </p>
        <a
          href={issueUrl}
          rel="noopener"
          target="_blank"
          class="inline-block mt-4 px-5 py-2.5 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium"
        >
          Submit via GitHub issue →
        </a>
        <p class="text-sm text-slate-500 mt-3">No GitHub account? The weekly scrape auto-indexes any public repo whose metadata identifies it as an MCP project.</p>
      </div>
    )}

  </section>
</BaseLayout>
