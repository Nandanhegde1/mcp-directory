---
import BaseLayout from '~/layouts/BaseLayout.astro';
const stripeLink = import.meta.env.PUBLIC_STRIPE_FEATURED_LINK || '';
---

<BaseLayout
  title="Get featured — MCP Directory"
  description="Promote your MCP server with a featured listing on the homepage and category pages for 30 days. $29 one-time."
>
  <section class="px-4 mx-auto max-w-2xl pt-10 pb-20">
    <h1 class="text-3xl font-bold text-white">Get featured — $29 / 30 days</h1>
    <p class="text-slate-300 mt-3">Reach AI engineers actively looking for MCP servers.</p>

    <ul class="mt-8 space-y-3 text-slate-200">
      <li class="flex gap-3"><span class="text-brand-500">✓</span> Top placement on the homepage's "Featured" rail</li>
      <li class="flex gap-3"><span class="text-brand-500">✓</span> Pinned at the top of your category page</li>
      <li class="flex gap-3"><span class="text-brand-500">✓</span> "Featured" badge on every card</li>
      <li class="flex gap-3"><span class="text-brand-500">✓</span> Edit your title, description, and links anytime</li>
      <li class="flex gap-3"><span class="text-brand-500">✓</span> 30-day money-back guarantee if you don't get clicks</li>
    </ul>

    <div class="mt-8">
      {stripeLink ? (
        <a href={stripeLink} target="_blank" rel="noopener" class="inline-block px-6 py-3 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium">
          Pay $29 → Get featured
        </a>
      ) : (
        <div class="rounded-lg border border-yellow-700/50 bg-yellow-900/20 p-4 text-sm text-yellow-200">
          ⚠️ Stripe Payment Link not configured. Set <code>PUBLIC_STRIPE_FEATURED_LINK</code> to enable.
        </div>
      )}
    </div>

    <p class="mt-4 text-sm text-slate-400">
      After payment, email us your repo URL — we'll add the featured flag and deploy within 24 hours.
    </p>
  </section>
</BaseLayout>
