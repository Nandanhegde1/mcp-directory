# Environment variables actually read by the code.

# GitHub Personal Access Token for the scraper (read-only, public repos)
# Get from: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# Canonical site URL for sitemap/OG tags (defaults to the live Worker)
SITE_URL=https://mcp-directory.nandanhegde1096.workers.dev

# Formspree form ID for /submit/ (optional — falls back to a prefilled GitHub issue)
PUBLIC_FORMSPREE_ID=
